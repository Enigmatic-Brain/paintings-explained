# Copy to ".env" for local dev (and set the same vars in Vercel for production).
# These are read server-side only — the anon key is never exposed to the browser.
# Supabase: Project Settings → API.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Optional: your production URL (used for canonical links / share cards).
SITE_URL=https://paintings-explained.vercel.app

# Optional: Fingerprint Pro (cookieless visitor identification).
# PUBLIC_ prefix = exposed to the browser on purpose (it's the publishable key,
# locked to your domain in the Fingerprint dashboard). Leave blank to disable.
PUBLIC_FINGERPRINT_API_KEY=
PUBLIC_FINGERPRINT_REGION=us
