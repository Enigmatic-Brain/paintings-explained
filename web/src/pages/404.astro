---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="That page doesn't exist.">
  <section class="section container nf">
    <p class="eyebrow">404</p>
    <h1>This frame is empty.</h1>
    <p>The page you're looking for isn't here — but there are plenty of paintings to explore.</p>
    <a class="btn btn--primary" href="/paintings">Browse paintings</a>
  </section>
</Base>

<style>
  .nf { max-width: 560px; display: grid; gap: var(--space-4); padding-block: var(--space-16); }
  .nf p { color: var(--color-ink-muted); font-size: var(--fs-500); }
  .nf .btn { justify-self: start; }
</style>
