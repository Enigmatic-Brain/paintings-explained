---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';
import Fingerprint from '../components/Fingerprint.astro';

interface Props {
  title: string;
  description?: string;
  image?: string | null;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | null;
}
const { title, description, image, type, jsonLd } = Astro.props;

// Cache at the CDN edge so pages are fast, while new/edited content still
// appears within ~a minute without a rebuild (stale-while-revalidate).
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=60, stale-while-revalidate=600',
);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Paintings Explained" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap"
    />
    <Seo title={title} description={description} image={image} type={type} jsonLd={jsonLd} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <Fingerprint />
  </body>
</html>
