---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <p class="site-footer__tag">
      <strong>Paintings Explained</strong> — the hidden details in the world's
      most-watched paintings.
    </p>
    <p class="site-footer__meta">
      Images are public-domain (CC0) from
      <a href="https://www.metmuseum.org/about-the-met/policies-and-documents/open-access" rel="noopener">The Met</a>
      and the
      <a href="https://www.artic.edu/open-access/open-access-images" rel="noopener">Art Institute of Chicago</a>.
      © {year}.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-16);
    background: var(--color-surface-2);
  }
  .site-footer__inner {
    padding-block: var(--space-8);
    display: grid;
    gap: var(--space-2);
  }
  .site-footer__tag { max-width: var(--measure); }
  .site-footer__meta {
    font-size: var(--fs-300);
    color: var(--color-ink-muted);
    max-width: var(--measure);
  }
</style>
