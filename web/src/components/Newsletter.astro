---
// Newsletter signup. Set NEWSLETTER_ACTION to your provider's HTTPS form
// endpoint (e.g. Buttondown:
// https://buttondown.email/api/emails/embed-subscribe/USERNAME).
// Until that's set the form is shown disabled — never a mailto:, which browsers
// flag as "not secure".
const action = import.meta.env.NEWSLETTER_ACTION;
const enabled = Boolean(action && action.startsWith('https://'));
---
<section class="newsletter" aria-labelledby="nl-title">
  <div class="newsletter__text">
    <h2 id="nl-title">One hidden detail, every week</h2>
    <p>
      Join the list to get a single fascinating painting — and the secret most
      people walk right past — in your inbox.
    </p>
  </div>
  <form class="newsletter__form" method="post" action={enabled ? action : undefined} target="_blank">
    <label class="visually-hidden" for="nl-email">Email address</label>
    <input
      id="nl-email"
      type="email"
      name="email"
      inputmode="email"
      autocomplete="email"
      required
      placeholder="you@example.com"
      disabled={!enabled}
      aria-describedby={enabled ? undefined : 'nl-note'}
    />
    <input type="hidden" name="embed" value="1" />
    <button class="btn btn--primary" type="submit" disabled={!enabled}>Subscribe</button>
  </form>
  {!enabled && <p id="nl-note" class="newsletter__note">Sign-up opens soon.</p>}
</section>

<style>
  .newsletter {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: grid;
    gap: var(--space-6);
  }
  .newsletter h2 { font-size: var(--fs-700); }
  .newsletter p { color: var(--color-ink-muted); margin-top: var(--space-2); }
  .newsletter__note { font-size: var(--fs-300); }
  .newsletter__form { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .newsletter__form input {
    flex: 1 1 220px;
    min-height: 44px;
    padding: var(--space-2) var(--space-4);
    font: inherit;
    color: var(--color-ink);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .newsletter__form input:focus-visible { border-color: var(--color-focus); }
  @media (min-width: 768px) {
    .newsletter { grid-template-columns: 1fr auto; align-items: center; }
    .newsletter__form { flex-wrap: nowrap; min-width: 380px; }
  }
</style>
