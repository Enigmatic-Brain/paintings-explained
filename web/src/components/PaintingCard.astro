---
import type { Painting } from '../lib/types';
interface Props { painting: Painting; eager?: boolean; }
const { painting: p, eager = false } = Astro.props;
const alt = `${p.title}${p.artist ? ' by ' + p.artist.name : ''}`;
---
<a class="card" href={`/paintings/${p.slug}`}>
  <div class="card__media">
    <img
      src={p.thumb_url ?? p.image_url}
      alt={alt}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
    />
    {p.hotspots.length > 0 && (
      <span class="card__badge">{p.hotspots.length} hidden {p.hotspots.length === 1 ? 'detail' : 'details'}</span>
    )}
  </div>
  <div class="card__body">
    <h3 class="card__title">{p.title}</h3>
    <p class="card__meta">
      {p.artist?.name}{p.year ? ` · ${p.year}` : ''}
    </p>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .card:focus-visible { transform: translateY(-4px); }
  .card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-surface-2);
  }
  .card__media img { width: 100%; height: 100%; object-fit: cover; }
  .card__badge {
    position: absolute;
    bottom: var(--space-2);
    left: var(--space-2);
    background: color-mix(in srgb, var(--color-viewer-bg) 86%, transparent);
    color: #fff;
    font-size: var(--fs-300);
    font-weight: 600;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
  .card__body { padding: var(--space-4); display: grid; gap: var(--space-1); }
  .card__title { font-size: var(--fs-600); }
  .card__meta { font-size: var(--fs-300); color: var(--color-ink-muted); max-width: none; }
</style>
