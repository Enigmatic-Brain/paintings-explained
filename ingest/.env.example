# Copy this file to ".env" and fill in your Supabase project values.
# Find them in Supabase: Project Settings → API.
#
# IMPORTANT: the service-role key bypasses Row Level Security. Keep it secret,
# use it ONLY here in the ingestion script — never put it in the website.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
